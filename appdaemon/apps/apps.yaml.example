# Example apps.yaml configuration.
# Copy relevant blocks into your apps.yaml and customize entity IDs.
#
# See DESIGN.md for the full SOP on adding new automations.

area_handler:
  module: area_handler
  class: AreaHandler
  priority: 10

state_manager:
  module: state_manager
  class: StateManager
  domains:
    - light
    - fan
    - cover
    - media_player
  exclude:
    - light.backyard_floodlight
    - light.0x84fd27fffebcd13a
  snapshot_path: "../data/state_manager.json"
  snapshot_interval: 60

global_automation_manager:
  module: automation_manager
  class: AutomationManager

global_notify:
  module: global_notify
  class: GlobalNotify
  default_notification_group: family
  groups:
    family:
      android:
        - mobile_app_my_android_phone
    critical_alert_phones:
      android:
        - mobile_app_my_android_phone
      ios:
        - mobile_app_my_iphone

all_lights:
  module: all_lights
  class: AllLights

simple_state_linker:
  module: simple_state_linker
  class: SimpleStateLinker
  grace_period: 2.0
  groups:
    - entities:
        - light.sofa_lamp
        - light.tv_backlight
    - area: "Office"
    - area: "Kitchen"
      domains: ["light"]
      exclude:
        - light.kitchen_sink_light

door_light_automation:
  module: door_light_automation
  class: DoorLightAutomation
  door_light_map:
    binary_sensor.doors_front_door:
      - light.porch_light
      - light.entrance_light
  timeout: 300
  sun_entity: sun.sun
  next_rising_entity: sensor.sun_next_rising
  next_setting_entity: sensor.sun_next_setting
  grace_period: 30

auto_lock_doors:
  module: auto_lock
  class: AutoLock
  door_lock_map:
    binary_sensor.doors_front_door: lock.front_door_lock
  enable_topic: home/autolock/front/enable
  timeout_topic: home/autolock/front/timeout

fan_auto_off:
  module: fan_auto_off
  class: FanAutoOff
  fans:
    fan.bedroom_fan:
      time_limit: 120        # minutes
      cutoff_time: "02:00:00"
      enforcement_time_start: "21:00:00"
      enforcement_time_end: "06:00:00"

water_sensor_monitor:
  module: water_sensor_monitor
  class: WaterSensorMonitor
  notification_group: "critical_alert_phones"
  send_tts: false
  tts_max_volume: true
  main_water_valve_switch: switch.main_water_valve
  water_sensors:
    - binary_sensor.kitchen_sink_water_leak
  shutoff_exclusion_sensors:
    - binary_sensor.ac_overflow_water_leak

republic_services_schedule:
  module: republic_services_schedule
  class: RepublicServicesSchedule
  schedule_hour: 6
  dependencies:
    - global_notify
